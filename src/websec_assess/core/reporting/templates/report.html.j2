<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Security Assessment Report - {{ scan.target.host }}</title>
<style>
  :root {
    --critical: #7a1f1f; --high: #c0392b; --medium: #d68910; --low: #2471a3; --info: #566573;
  }
  body { font-family: -apple-system, Segoe UI, Roboto, Arial, sans-serif; margin: 0; padding: 0; background: #f7f7f8; color: #1b1f23; }
  header { background: #111418; color: #fff; padding: 24px 32px; }
  header h1 { margin: 0 0 4px; font-size: 22px; }
  header .meta { color: #b7becb; font-size: 13px; }
  main { max-width: 980px; margin: 0 auto; padding: 24px 32px 64px; }
  .summary { display: flex; gap: 12px; margin: 20px 0 32px; flex-wrap: wrap; }
  .pill { padding: 10px 16px; border-radius: 8px; color: #fff; font-weight: 600; min-width: 90px; text-align: center; }
  .pill small { display: block; font-weight: 400; font-size: 11px; opacity: .85; }
  .pill.critical { background: var(--critical); } .pill.high { background: var(--high); }
  .pill.medium { background: var(--medium); } .pill.low { background: var(--low); } .pill.info { background: var(--info); }
  .finding { background: #fff; border: 1px solid #e1e4e8; border-radius: 8px; padding: 18px 20px; margin-bottom: 14px; border-left: 5px solid #ccc; }
  .finding.critical { border-left-color: var(--critical); } .finding.high { border-left-color: var(--high); }
  .finding.medium { border-left-color: var(--medium); } .finding.low { border-left-color: var(--low); } .finding.info { border-left-color: var(--info); }
  .badge { display: inline-block; font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 4px; color: #fff; text-transform: uppercase; margin-right: 6px; }
  .badge.critical { background: var(--critical); } .badge.high { background: var(--high); }
  .badge.medium { background: var(--medium); } .badge.low { background: var(--low); } .badge.info { background: var(--info); }
  .finding h3 { margin: 4px 0 8px; }
  .meta-row { color: #57606a; font-size: 12.5px; margin-bottom: 10px; }
  code { background: #f0f1f3; padding: 1px 5px; border-radius: 4px; font-size: 12.5px; }
  .evidence { background: #f6f8fa; border: 1px solid #e1e4e8; border-radius: 6px; padding: 10px 12px; font-size: 12.5px; margin-top: 8px; }
  table { border-collapse: collapse; width: 100%; margin: 8px 0; }
  th, td { text-align: left; padding: 6px 10px; border-bottom: 1px solid #e1e4e8; font-size: 13px; }
  section h2 { border-bottom: 2px solid #e1e4e8; padding-bottom: 6px; margin-top: 40px; }
  .asset-group h4 { margin-bottom: 6px; }
</style>
</head>
<body>
<header>
  <h1>Security Assessment Report</h1>
  <div class="meta">
    Target: {{ scan.target.base_url }} &middot; Profile: {{ scan.profile.value }} &middot;
    Status: {{ scan.status.value }} &middot; Scan ID: {{ scan.id }}
  </div>
</header>
<main>
  <section class="summary">
    {% for sev, count in severity_counts.items() %}
    <div class="pill {{ sev }}">{{ count }}<small>{{ sev }}</small></div>
    {% endfor %}
  </section>

  <section>
    <h2>Findings ({{ total_findings }})</h2>
    {% for f in findings %}
    <div class="finding {{ f.severity.value }}">
      <span class="badge {{ f.severity.value }}">{{ f.severity.value }}</span>
      <span class="badge {{ f.severity.value }}" style="opacity:.7">confidence: {{ f.confidence.value }}</span>
      <h3>{{ f.title }}</h3>
      <div class="meta-row">
        Plugin: {{ f.plugin }} ({{ f.category }}) &middot; URL: <code>{{ f.affected_url }}</code>
        {% if f.cwe %} &middot; {{ f.cwe }}{% endif %}
        {% if f.owasp %} &middot; {{ f.owasp }}{% endif %}
      </div>
      <p>{{ f.description }}</p>
      {% if f.evidence %}
      <div class="evidence">
        {% for ev in f.evidence %}
          <div>{{ ev.description }}{% if ev.matched_value %} &mdash; <code>{{ ev.matched_value }}</code>{% endif %}</div>
        {% endfor %}
      </div>
      {% endif %}
      {% if f.remediation %}<p><strong>Remediation:</strong> {{ f.remediation }}</p>{% endif %}
      {% if f.references %}
      <p><strong>References:</strong>
        {% for ref in f.references %}<br><code>{{ ref }}</code>{% endfor %}
      </p>
      {% endif %}
    </div>
    {% else %}
    <p>No findings recorded.</p>
    {% endfor %}
  </section>

  <section>
    <h2>Asset Inventory ({{ total_assets }})</h2>
    {% for asset_type, items in assets_by_type.items() %}
    <div class="asset-group">
      <h4>{{ asset_type }} ({{ items|length }})</h4>
      <table>
        {% for item in items %}
        <tr><td><code>{{ item.value }}</code></td><td>{{ item.source_plugin }}</td></tr>
        {% endfor %}
      </table>
    </div>
    {% else %}
    <p>No assets recorded.</p>
    {% endfor %}
  </section>
</main>
</body>
</html>
